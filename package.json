{
  "name": "@bariumstudios/cesium-timeline",
  "version": "0.1.0",
  "description": "SVG-based timeline component for Cesium with clock integration",
  "type": "module",
  "main": "./dist/cesium-timeline.umd.cjs",
  "module": "./dist/cesium-timeline.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cesium-timeline.js",
      "require": "./dist/cesium-timeline.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --config vite.demo.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "peerDependencies": {
    "cesium": "^1.100.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": ">=18",
    "@types/react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vitejs/plugin-react": "^4.2.0",
    "cesium": "^1.100.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.1.0"
  }
}
