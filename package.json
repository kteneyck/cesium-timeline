{
  "name": "@kteneyck/cesium-timeline-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-framework timeline component for Cesium with clock integration",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/react",
    "packages/angular"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:react && npm run build:angular",
    "build:core": "npm run build -w @kteneyck/cesium-timeline-core",
    "build:react": "npm run build -w @kteneyck/cesium-timeline-react",
    "build:angular": "npm run build -w @kteneyck/cesium-timeline-angular",
    "dev:demo-react": "vite --config vite.react-demo.config.ts",
    "dev:demo-angular": "vite --config vite.angular-demo.config.ts",
    "test": "npm run test:core && npm run test:react && npm run test:angular",
    "test:core": "npm test -w @kteneyck/cesium-timeline-core",
    "test:react": "npm test -w @kteneyck/cesium-timeline-react",
    "test:angular": "npm test -w @kteneyck/cesium-timeline-angular",
    "clean": "rimraf packages/core/dist packages/react/dist packages/angular/dist",
    "lint": "eslint packages/*/src --ext .ts,.tsx --cache",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/react/tsconfig.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@angular/build": "^21.2.8",
    "@angular/forms": "^21.2.10",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vitejs/plugin-react": "^4.2.0",
    "cesium": "^1.142.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@babel/core": "7.29.7",
    "js-yaml": "^4.2.0",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@angular/build": {
      "vite": "7.3.5"
    }
  }
}
